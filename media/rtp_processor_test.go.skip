package media

import (
	"testing"
	"time"
)

func TestRTPProcessor_Initialize(t *testing.T) {
	processor, err := NewRTPProcessor(12345678, 96, 48000)
	if err != nil {
		t.Fatalf("Failed to create RTP processor: %v", err)
	}

	stats := processor.GetRTPStats()
	if stats == nil {
		t.Error("Expected RTP stats")
	}
}

func TestRTPProcessor_Packetize(t *testing.T) {
	processor, _ := NewRTPProcessor(12345678, 96, 48000)

	frame := &MediaFrame{
		Type:      MediaTypeAudio,
		Timestamp: 160,
		Sequence:  1,
		Payload:   []byte{1, 2, 3, 4, 5, 6, 7, 8},
		KeyFrame:  false,
	}

	packets, err := processor.Packetize(frame)
	if err != nil {
		t.Fatalf("Packetize failed: %v", err)
	}

	if len(packets) == 0 {
		t.Error("Expected at least one packet")
	}
}

func TestRTPProcessor_Depacketize(t *testing.T) {
	processor, _ := NewRTPProcessor(12345678, 96, 48000)

	packet := &RTPPacket{
		Version:     2,
		Marker:      true,
		PayloadType: 96,
		Sequence:    100,
		Timestamp:   160,
		SSRC:        12345678,
		Payload:     []byte{1, 2, 3, 4, 5, 6, 7, 8},
	}

	frame, err := processor.Depacketize(packet)
	if err != nil {
		t.Fatalf("Depacketize failed: %v", err)
	}

	if frame == nil {
		t.Error("Expected frame")
	}
}

