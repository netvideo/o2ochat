func TestRTPProcessor_HandleNACK(t *testing.T) {
	processor, _ := NewRTPProcessor(12345678, 96, 48000)

	seqNums := []uint16{100, 101, 102}
	packets, err := processor.HandleNACK(seqNums)
	if err != nil {
		t.Fatalf("HandleNACK failed: %v", err)
	}

	_ = packets
}

