func TestMediaManager_JoinCall(t *testing.T) {
	manager := NewMediaManager()
	manager.Initialize()

	session, _ := manager.CreateCallSession(DefaultCallConfig())
	sessionID := session.GetSessionID()

	joinedSession, err := manager.JoinCall(sessionID)
	if err != nil {
		t.Fatalf("JoinCall failed: %v", err)
	}

	if joinedSession.GetSessionID() != sessionID {
		t.Errorf("Session ID mismatch")
	}
}

