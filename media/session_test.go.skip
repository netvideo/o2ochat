		t.Errorf("RefreshDevices failed: %v", err)
	}
}

func TestMediaManagerFactory(t *testing.T) {
	factory := NewMediaManagerFactory()

	manager, err := factory.CreateDefault()
	if err != nil {
		t.Fatalf("CreateDefault failed: %v", err)
	}

	if manager == nil {
		t.Error("Expected manager")
	}

	config := DefaultMediaManagerConfig()
	manager2, err := factory.CreateWithConfig(config)
	if err != nil {
		t.Fatalf("CreateWithConfig failed: %v", err)
	}

	if manager2 == nil {
		t.Error("Expected manager2")
	}
}

func TestDefaultConfigs(t *testing.T) {
	audioConfig := DefaultAudioConfig()
	if audioConfig.Codec != "opus" {
		t.Errorf("Expected opus codec")
	}
	if audioConfig.SampleRate != 48000 {
		t.Errorf("Expected 48000 sample rate")
	}

	videoConfig := DefaultVideoConfig()
	if videoConfig.Codec != "vp8" {
		t.Errorf("Expected vp8 codec")
	}
	if videoConfig.Width != 640 {
		t.Errorf("Expected 640 width")
	}

	callConfig := DefaultCallConfig()
	if callConfig.MaxBitrate != 1000000 {
		t.Errorf("Expected 1000000 max bitrate")
	}
	if callConfig.UseFEC != true {
		t.Errorf("Expected FEC enabled")
	}
}
