func TestMediaManager_GetUptime(t *testing.T) {
	manager := NewMediaManager()
	manager.Initialize()

	uptime := manager.GetUptime()
	if uptime == 0 {
		t.Error("Expected uptime > 0")
	}
}

func TestMediaManager_GetSessionCount(t *testing.T) {
	manager := NewMediaManager()
	manager.Initialize()

	count := manager.GetSessionCount()
	if count != 0 {
		t.Errorf("Expected 0 sessions initially, got %d", count)
	}

	manager.CreateCallSession(DefaultCallSession())

	count = manager.GetSessionCount()
	if count != 1 {
		t.Errorf("Expected 1 session, got %d", count)
	}
}

