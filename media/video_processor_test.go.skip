package media

import (
	"testing"
)

func TestVideoProcessor_Initialize(t *testing.T) {
	processor, err := NewVideoProcessor(640, 480)
	if err != nil {
		t.Fatalf("Failed to create video processor: %v", err)
	}

	if processor.GetWidth() != 640 {
		t.Errorf("Expected width 640, got %d", processor.GetWidth())
	}
	if processor.GetHeight() != 480 {
		t.Errorf("Expected height 480, got %d", processor.GetHeight())
	}
}

func TestVideoProcessor_ProcessFrame(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	frame := make([]byte, 460800)
	for i := range frame {
		frame[i] = byte(i % 256)
	}

	processed, err := processor.ProcessFrame(frame)
	if err != nil {
		t.Fatalf("ProcessFrame failed: %v", err)
	}

	if len(processed) != len(frame) {
		t.Errorf("Output length mismatch")
	}
}

func TestVideoProcessor_Scale(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.Scale(1280, 720)
	if err != nil {
		t.Errorf("Scale failed: %v", err)
	}

	if processor.GetWidth() != 1280 {
		t.Errorf("Expected width 1280, got %d", processor.GetWidth())
	}
	if processor.GetHeight() != 720 {
		t.Errorf("Expected height 720, got %d", processor.GetHeight())
	}
}

func TestVideoProcessor_Crop(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.Crop(100, 100, 320, 240)
	if err != nil {
		t.Errorf("Crop failed: %v", err)
	}
}

func TestVideoProcessor_Crop_InvalidDimensions(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.Crop(-10, 100, 320, 240)
	if err == nil {
		t.Error("Expected error for invalid crop dimensions")
	}

	err = processor.Crop(100, 100, 1000, 1000)
	if err == nil {
		t.Error("Expected error for crop exceeding bounds")
	}
}

func TestVideoProcessor_Rotate(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.Rotate(90)
	if err != nil {
		t.Errorf("Rotate failed: %v", err)
	}

	err = processor.Rotate(180)
	if err != nil {
		t.Errorf("Rotate 180 failed: %v", err)
	}

	err = processor.Rotate(270)
	if err != nil {
		t.Errorf("Rotate 270 failed: %v", err)
	}
}

func TestVideoProcessor_Rotate_InvalidAngle(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.Rotate(45)
	if err == nil {
		t.Error("Expected error for invalid angle")
	}
}

func TestVideoProcessor_ApplyFilter(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	filters := []string{"grayscale", "blur", "sharpen", "edge", "sepia", "invert"}

	for _, filter := range filters {
		err := processor.ApplyFilter(filter)
		if err != nil {
			t.Errorf("ApplyFilter %s failed: %v", filter, err)
		}
	}
}

func TestVideoProcessor_ApplyFilter_Unsupported(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.ApplyFilter("unknown_filter")
	if err == nil {
		t.Error("Expected error for unsupported filter")
	}
}

func TestVideoProcessor_ColorAdjustment(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	processor.SetBrightness(0.2)
	processor.SetContrast(1.1)
	processor.SetSaturation(0.9)

	frame := make([]byte, 100)
	processed, err := processor.ProcessFrame(frame)
	if err != nil {
		t.Fatalf("ProcessFrame failed: %v", err)
	}

	if len(processed) != len(frame) {
		t.Errorf("Output length mismatch")
	}
}

func TestVideoProcessor_Reset(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	processor.Scale(1280, 720)
	processor.ApplyFilter("grayscale")
	processor.SetBrightness(0.5)

	err := processor.Reset()
	if err != nil {
		t.Errorf("Reset failed: %v", err)
	}

	if processor.GetWidth() != 640 || processor.GetHeight() != 480 {
		t.Error("Expected dimensions reset to original values")
	}
}

func TestVideoProcessor_Close(t *testing.T) {
	processor, _ := NewVideoProcessor(640, 480)

	err := processor.Close()
	if err != nil {
		t.Errorf("Close failed: %v", err)
	}
}

func TestSimpleVideoCapturer_Initialize(t *testing.T) {
	capturer, err := NewSimpleVideoCapturer(640, 480, 30)
	if err != nil {
		t.Fatalf("Failed to create capturer: %v", err)
	}

	resolutions := capturer.GetSupportedResolutions()
	if len(resolutions) == 0 {
		t.Error("Expected at least one supported resolution")
	}
}

func TestSimpleVideoCapturer_StartStop(t *testing.T) {
	capturer, _ := NewSimpleVideoCapturer(640, 480, 30)

	err := capturer.Start()
	if err != nil {
		t.Errorf("Start failed: %v", err)
	}

	err = capturer.Stop()
	if err != nil {
		t.Errorf("Stop failed: %v", err)
	}
}

func TestSimpleVideoCapturer_GetFrame(t *testing.T) {
	capturer, _ := NewSimpleVideoCapturer(640, 480, 30)

	capturer.Start()
	defer capturer.Stop()

	frame, err := capturer.GetFrame()
	if err != nil {
		t.Fatalf("GetFrame failed: %v", err)
	}

	expectedSize := 640 * 480 * 3 / 2
	if len(frame) != expectedSize {
		t.Errorf("Expected frame size %d, got %d", expectedSize, len(frame))
	}
}

func TestSimpleVideoCapturer_SetResolution(t *testing.T) {
	capturer, _ := NewSimpleVideoCapturer(640, 480, 30)

	err := capturer.SetResolution(1280, 720)
	if err != nil {
		t.Errorf("SetResolution failed: %v", err)
	}
}

func TestSimpleVideoCapturer_SetFrameRate(t *testing.T) {
	capturer, _ := NewSimpleVideoCapturer(640, 480, 30)

	err := capturer.SetFrameRate(60)
	if err != nil {
		t.Errorf("SetFrameRate failed: %v", err)
	}
}

func TestSimpleVideoRenderer_Initialize(t *testing.T) {
	renderer := NewSimpleVideoRenderer()

	err := renderer.Initialize()
	if err != nil {
		t.Errorf("Initialize failed: %v", err)
	}
}

func TestSimpleVideoRenderer_RenderFrame(t *testing.T) {
	renderer := NewSimpleVideoRenderer()
	renderer.Initialize()

	frame := make([]byte, 460800)
	err := renderer.RenderFrame(frame, 640, 480)
	if err != nil {
		t.Errorf("RenderFrame failed: %v", err)
	}
}

func TestSimpleVideoRenderer_SetVolume(t *testing.T) {
	renderer := NewSimpleVideoRenderer()

	err := renderer.SetVolume(50)
	if err != nil {
		t.Errorf("SetVolume failed: %v", err)
	}

	err = renderer.SetVolume(150)
	if err == nil {
		t.Error("Expected error for volume > 100")
	}

	err = renderer.SetVolume(-10)
	if err == nil {
		t.Error("Expected error for volume < 0")
	}
}

func TestSimpleVideoRenderer_GetCapabilities(t *testing.T) {
	renderer := NewSimpleVideoRenderer()

	caps := renderer.GetCapabilities()
	if caps == nil {
		t.Error("Expected capabilities")
	}

	if len(caps.SupportedCodecs) == 0 {
		t.Error("Expected at least one supported codec")
	}
}

func TestSimpleVideoRenderer_Close(t *testing.T) {
	renderer := NewSimpleVideoRenderer()
	renderer.Initialize()

	err := renderer.Close()
	if err != nil {
		t.Errorf("Close failed: %v", err)
	}
}

func TestVideoDeviceManager_GetDevices(t *testing.T) {
	manager := NewVideoDeviceManager()

	devices := manager.GetDevices()
	if len(devices) == 0 {
		t.Error("Expected at least one device")
	}
}

func TestVideoDeviceManager_SelectDevice(t *testing.T) {
	manager := NewVideoDeviceManager()

	err := manager.SelectDevice("default-video")
	if err != nil {
		t.Errorf("SelectDevice failed: %v", err)
	}

	device := manager.GetSelectedDevice()
	if device == nil {
		t.Error("Expected selected device")
	}
}

func TestVideoDeviceManager_GetDefaultDevice(t *testing.T) {
	manager := NewVideoDeviceManager()

	device := manager.GetDefaultDevice()
	if device == nil {
		t.Error("Expected default device")
	}
}
